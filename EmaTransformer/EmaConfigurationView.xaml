<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:IoAssistant.Transformers"
             x:Class="IoAssistant.Transformers.EmaConfigurationView">

    <Grid
        Margin="0"
        Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        
        <Border
            Grid.Row="0"
            Margin="0,0,0,8"
            Padding="12"
            Style="{DynamicResource MainPanelBorder}">
            
            <local:EmaConfigurationComponent />
        </Border>
        
        <Border
            Grid.Row="1"
            Margin="0,8,0,10"
            Padding="12"
            Style="{DynamicResource MainPanelBorder}">
            
            <local:EmaInformationComponent />
        </Border>
    </Grid>


</ContentView>