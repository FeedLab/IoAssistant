<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IoAssistant.Transformers.EmaInformationComponent">

    <VerticalStackLayout
        Spacing="20"
        Padding="8">

        <!-- Header -->
        <Label Text="Exponential Moving Average (EMA)"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="Black" />

        <!-- Fast EMA Section -->
        <Border Stroke="DarkRed"
                StrokeThickness="2"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 10"
                Padding="15">
            <VerticalStackLayout Spacing="2">
                <Label Text="Fast EMA (Short-Term)"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="DarkRed" />
                <Label Text="• Goal: Immediate responsiveness" FontSize="12" />
                <Label Text="• Behavior: Reacts quickly to new values by weighting recent data heavily"
                       FontSize="12" />
                <Label Text="• Best for: Catching short-term swings and early reversals" FontSize="12" />
                <Label Text="• Trade-off: Prone to noise and false signals" FontSize="12" />
            </VerticalStackLayout>
        </Border>

        <!-- Slow EMA Section -->
        <Border Stroke="Green"
                StrokeThickness="2"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 10"
                Padding="15">
            <VerticalStackLayout Spacing="2">
                <Label Text="Slow EMA (Long-Term)"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="Green" />
                <Label Text="• Goal: Stability and trend clarity" FontSize="12" />
                <Label Text="• Behavior: Moves gradually by averaging data over a longer period" FontSize="12" />
                <Label Text="• Best for: Identifying overall direction and filtering out volatility"
                       FontSize="12" />
                <Label Text="• Trade-off: Lags behind current price action" FontSize="12" />
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>

</ContentView>
